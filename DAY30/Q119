#include <stdio.h>

struct Employee {
    int id;
    char name[50];
    float salary;
};

int main() {
    struct Employee e[100];
    int n = 0, choice, i;

    do {
        printf("\n1. Add Employee");
        printf("\n2. Display Employees");
        printf("\n3. Exit");
        printf("\nEnter choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                printf("Employee ID: ");
                scanf("%d", &e[n].id);

                printf("Employee Name: ");
                scanf(" %[^\n]", e[n].name);

                printf("Salary: ");
                scanf("%f", &e[n].salary);

                n++;
                break;

            case 2:
                printf("\nID\tName\t\tSalary\n");
                for(i = 0; i < n; i++) {
                    printf("%d\t%s\t\t%.2f\n",
                           e[i].id,
                           e[i].name,
                           e[i].salary);
                }
                break;

            case 3:
                printf("Exiting...\n");
                break;

            default:
                printf("Invalid Choice!\n");
        }

    } while(choice != 3);

    return 0;
}